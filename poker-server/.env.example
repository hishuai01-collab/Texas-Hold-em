# ── 德州扑克服务端环境变量配置参考 ──
# 复制本文件为 .env 并填入实际值（不要提交 .env 到仓库）
# 生产环境请使用 /etc/poker-server/env

# ── 必需变量 ──

# Redis 连接字符串
# 格式: redis://[:password@]host:port/db
# 生产环境务必设置强密码
# REDIS_URL=redis://:your-strong-password@127.0.0.1:6379/0

# ── Telegram 通知（可选，生产建议配置） ──

# Telegram Bot Token（从 @BotFather 获取）
# TG_BOT_TOKEN=your_bot_token_here

# 管理员 Telegram 用户 ID（用于 /status /ban /unban /health 等命令）
# ADMIN_TG_ID=123456789

# 告警通知群组 Chat ID（用于异常告警推送）
# TELEGRAM_CHAT_ID=-1001234567890

# ── 服务端口（可选，有默认值） ──

# WebSocket 服务端口（默认 8080）
# PORT=8080

# HTTP API 服务端口（默认 8081）
# HTTP_API_PORT=8081

# Prometheus 指标端口（默认 9091）
# METRICS_PORT=9091

# ── Supabase 认证（可选，若启用手机号/社交登录） ──

# Supabase 项目 JWT Secret（用于验证前端传来的 Supabase access_token）
# 在 Supabase 项目设置 > API > JWT Secret 获取
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── 安全配置（可选，有默认值） ──

# Action 签名密钥（HMAC-SHA256）
# 生产环境应使用 KMS 管理的密钥，长度至少 32 字节
# ACTION_SIG_KEY=poker-dev-action-sig-key

# 是否强制开启 Action 签名校验（1=开启，0或空=兼容模式）
# ACTION_SIG_HOOK=0

# CORS 允许的域名列表（逗号分隔，默认 *）
# ALLOWED_ORIGINS=https://poker.example.com

# IP 拉黑时长（毫秒，默认 60000 = 1 分钟）
# IP_BAN_TTL_MS=60000

# 触发 IP 拉黑的违规次数（默认 3）
# IP_STRIKES_TO_BAN=3

# ── 演示/开发配置 ──

# 默认牌桌的机器人数量（仅演示/联调用）
# BOTS=3

# 监听地址（production=127.0.0.1, 其他=0.0.0.0）
# NODE_ENV=development