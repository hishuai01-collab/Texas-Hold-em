    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "优先使用 poker_reconnect_errors_total / poker_reconnect_attempts_total。当前后端尚无这两个专用指标，因此回退为异常断开相对在线连接的代理值；该代理值用于告警观察，不等同于精确的重连失败率。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "(100 * sum(rate(poker_reconnect_errors_total[$__rate_interval])) / clamp_min(sum(rate(poker_reconnect_attempts_total[$__rate_interval])), 1)) or (100 * sum(rate(poker_abnormal_disconnects_total[$__rate_interval])) / clamp_min(avg_over_time(poker_active_connections[$__rate_interval]), 1))",
          "legendFormat": "重连错误率 / 异常断开代理",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "重连错误率",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "优先使用 poker_messages_total 的全量消息速率。当前后端尚无全量消息计数器，因此回退显示 poker_gateway_rejections_total 的网关拒绝消息速率。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(poker_messages_total[$__rate_interval])) or sum(rate(poker_gateway_rejections_total[$__rate_interval]))",
          "legendFormat": "消息吞吐 / 网关拒绝回退",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "消息吞吐量",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
